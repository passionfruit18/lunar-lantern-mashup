{
    "$schema": "https://schema.railpack.com",
    "packages": {
      "node": "20"
    },
    "steps": {
      "build": {
        "commands": [
          "npm install",
          "npm run build"
        ]
      }
    },
    "deploy": {
        "startCommand": "gunicorn --worker-class gevent -w 1 --bind 0.0.0.0:$PORT app:app"
    }
  }